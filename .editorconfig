root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yaml,csproj,props,targets,slnx}]
indent_size = 2

[*.{ts,tsx,js,jsx,css,html}]
indent_size = 2

[*.cs]
# Naming and style: rely on dotnet defaults; deviations kept minimal and explicit.
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_diagnostic.CA1305.severity = warning   # IFormatProvider — date/number formatting correctness matters here
