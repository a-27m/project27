#compdef p27
# zsh completion for p27. Install with `p27 completion zsh > "<fpath-dir>/_p27"`,
# or run scripts/install-completion.sh. Do not edit: generated by `p27 completion zsh`.
#
# Every candidate comes from `p27 __complete`, which walks the real command tree, so this
# script never has to know what p27's commands are. Descriptions are passed to _describe,
# which is also what lets fzf-tab render them (and its preview) with no extra setup.

_p27() {
  local -a reply_values reply_display
  local -a output
  local line value description directive
  local curcontext="$curcontext" state

  # words/CURRENT come from zsh's completion system, already dequoted: a value such as
  # "Alpha Project" is a single element. Pass the committed words plus the word under the
  # cursor (which may be empty) straight through as argv.
  local -a request
  request=("${words[@]:0:$((CURRENT - 1))}" "${words[CURRENT]}")

  output=("${(@f)$(p27 __complete -- "${request[@]}" 2>/dev/null)}")
  (( ${#output} )) || return 1

  # The last line is the directive; everything before it is a candidate.
  directive="${output[-1]}"
  output=("${output[@]:0:$((${#output} - 1))}")

  for line in "${output[@]}"; do
    [[ -n "$line" ]] || continue
    value="${line%%$'\t'*}"
    if [[ "$line" == *$'\t'* ]]; then
      description="${line#*$'\t'}"
    else
      description=""
    fi
    reply_values+=("$value")
    # _describe splits display entries on the first unescaped colon, and p27 uses colons
    # in values (uid:5) and descriptions alike.
    reply_display+=("${value//:/\\:}:${description//:/\\:}")
  done

  if (( ${#reply_values} )); then
    _describe -t p27-candidates 'p27' reply_display reply_values -- && return 0
  fi

  case "$directive" in
    :p27files) _files -g '*.p27' && return 0 ;;
    :files) _files && return 0 ;;
  esac

  return 1
}

# fzf's `**` trigger (its own completion.zsh, not fzf-tab) looks this function up by name.
# Plain TAB is unaffected and still goes through _p27 above.
_fzf_complete_p27() {
  local -a request
  local lbuf="$1"
  # ${(z)...} splits the way the shell would; prefix is set by fzf to the typed word.
  request=(${(z)lbuf})
  request+=("${prefix}")
  _fzf_complete --ansi --reverse --with-nth=1 --delimiter='\t' -- "$@" < <(
    p27 __complete -- "${request[@]}" 2>/dev/null | command grep -v '^:'
  )
}

# Insert only the value, never the description column.
_fzf_complete_p27_post() {
  command awk -F '\t' '{print $1}'
}

_p27 "$@"
